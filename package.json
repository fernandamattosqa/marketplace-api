    "report:evidence": "node scripts/gerar-evidencias.js",
    "report:perf": "node scripts/gerar-performance-baseline.js",
    "report:html": "node scripts/gerar-relatorio-html.js"
  },
  "devDependencies": {
     "@cucumber/cucumber": "^12.2.0"
  }
